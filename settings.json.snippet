// Merge this "hooks" block into your ~/.claude/settings.json.
// If you already have a "hooks" key, merge per-event (PreToolUse / PostToolUse / Stop)
// rather than replacing the whole object.
//
// Placeholders (setup.sh fills these in for you at install):
//   <kit-dir>     → absolute path to the Svaha kit clone (the folder holding bin/, hooks/, the
//                   command templates). This is where the MACHINERY lives — fixed, baked ONCE at
//                   install. Every path in this file resolves to <kit-dir> (the guard scripts and
//                   the allowed-directory below all point at the kit, not at any one project).
//   <system-dir>  → a PROJECT's data root (the folder holding next/, ledger/, _LOADUP.md). This is
//                   PER-PROJECT and discovered at RUNTIME (the nearest ancestor of your CWD with a
//                   _LOADUP.md) — so it is deliberately NOT baked here; it never appears in settings.
//   ~/.claude/hooks/* paths are literal — they live in your global Claude config, leave them as-is.
//
// Wiring:
//   SessionStart (all)                 → session-start-marker.sh — stamps a per-session start marker so session-end-backstop
//                                        can tell precisely whether a _NEXT was written THIS session (backstop falls back to
//                                        a 6h time window without it).
//   PreToolUse  (Bash|Edit|Write|Read) → security-guard.py  — blocks secret reads + catastrophic ops; asks on force-push/reset --hard
//   PreToolUse  (Edit|Write|MultiEdit) → version-guard.py   — HARD-BLOCKS edits to frozen artifacts (_NEXT_NNN.md + `frozen: true`)
//   PreToolUse  (Edit|Write|MultiEdit) → drift-guard.py     — surfaces coupled files before a structural edit
//   PostToolUse (every tool)           → context-canary.sh  — tracks context fill (transcript byte-size), nudges at thresholds
//   Stop  group 1                      → launchpad-nudge.sh  — reminds to write _NEXT / emit opener (byte-size trigger)
//                                        memory-reflect.sh   — prompts memory hygiene pass
//                                        resume-line-guard.sh — validates the resume:/Next-session line points at a live _NEXT
//   Stop  group 2                      → coherence-check.py --stop — final structural-coherence gate
//   SessionEnd (not clear/resume)      → session-end-backstop.sh — durability catch: if NO _NEXT was written this session,
//                                        tell the next session to run /handoff or /reflect. Fires once, event-driven.
//   PreCompact (all)                   → session-end-backstop.sh — same catch before a context-wall /compact wipes the thread.
//
// PERMISSIONS (no per-action flood — reads/inspection silent, danger always gated, edits are YOUR choice).
//   If you already have a "permissions" key, merge per-array (allow / ask / deny).
//
//   ► EDIT MODE — pick one (ships as A):
//     A) GRANT ONCE (silent edits) — keep "Edit(**)", "Write(**)", "MultiEdit(**)" in "allow" below.
//        Installing this is your one-time consent; Claude then edits without re-asking, ever.
//     B) ASK PER SESSION — delete those three lines from "allow". The first edit each session asks once
//        (press "2" = allow for the session). Either way, push/delete/secrets stay gated.
//
//   allow → SILENT: all bash via Bash(*) — the deny/ask lists below gate the dangerous ops so a granular
//           per-command allowlist just produces a permissions flood on every slash-command's compound bash.
//           File ops (Read/Edit/Write/MultiEdit) are also allowed in Mode A. Bash(*) does NOT override
//           ask/deny — those take precedence, so git push, rm, curl still prompt, rm -rf still hard-blocks.
//   additionalDirectories → registers the <kit-dir> (where bin/ + hooks/ live) as an allowed directory,
//           so running the kit's guard scripts + reading its files never trips "Path is outside allowed
//           working directories" — the #1 newcomer permission flood, hit because you launch Claude IN your
//           project, leaving the kit outside CWD. Your project's own data (next/, ledger/, _LOADUP.md) is in
//           CWD and already allowed. Absolute path (no ~); setup.sh fills it in. Without it, even a perfect
//           merge still prompts on every kit-script run.
//   ask   → confirm EVERY time: git push, gh, rm, curl/wget, reset --hard  (publish · destructive · network egress).
//   deny  → hard-blocked: secret reads (.env/.pem/.ssh/keys), rm -rf, sudo, pipe-to-shell.
//   Precedence deny > ask > allow — even a risky "allow always" is still caught by the ask/deny floor.
//   deny is the first layer; security-guard.py (wired below) is the backstop; version-guard hard-blocks frozen-file edits.
{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "MultiEdit(**)",
      "Bash(*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git remote add:*)",
      "Bash(gh:*)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/id_rsa*)",
      "Read(**/credentials*)",
      "Read(**/.aws/**)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(wget:* | sh)",
      "Bash(wget:* | bash)"
    ],
    "additionalDirectories": [
      "<kit-dir>"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-start-marker.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 <kit-dir>/bin/security-guard.py",
            "timeout": 10,
            "statusMessage": "security-guard"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 <kit-dir>/bin/version-guard.py",
            "timeout": 10,
            "statusMessage": "version-guard"
          },
          {
            "type": "command",
            "command": "python3 <kit-dir>/bin/drift-guard.py",
            "timeout": 10,
            "statusMessage": "drift-guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/context-canary.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/launchpad-nudge.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/memory-reflect.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/resume-line-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 <kit-dir>/bin/coherence-check.py --stop",
            "timeout": 10,
            "statusMessage": "coherence-check"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "logout|prompt_input_exit|other",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-end-backstop.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-end-backstop.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
