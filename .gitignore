# Python bytecode (never ship author-machine compiled artifacts)
__pycache__/
*.py[cod]

# setup.sh writes this when you already have a settings.json — local merge artifact
settings.generated.json

# macOS cruft
.DS_Store

# local preview config (dev-only, never shipped)
.claude/

# runtime machine logs — created by the PreToolUse guards, per-machine
ledger/security-guard-log.jsonl
ledger/version-guard-log.jsonl

# Consumed-handoff sidecars are runtime state, not source
next/*.consumed

# _ARCHIVE/ is local insurance (superseded files kept before mutating) — not shipped.
# Keep only the README explainer; the archived files themselves stay on-machine.
_ARCHIVE/*
!_ARCHIVE/README.md
